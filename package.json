{
  "name": "geo-course",
  "version": "1.0.0",
  "private": true,
  "description": "GEO 课程 monorepo（小程序 + 后端 + Admin 后台 + 共享类型）",
  "scripts": {
    "sync:admin-static": "bash ./scripts/sync-admin-static.sh",
    "build:shared": "pnpm --filter @geo/shared build",
    "dev:shared": "pnpm --filter @geo/shared dev",
    "dev:miniapp": "pnpm --filter @geo/miniapp dev:weapp",
    "dev:server": "pnpm --filter @geo/server dev",
    "dev:admin": "pnpm --filter @geo/admin dev",
    "build:miniapp": "pnpm --filter @geo/miniapp build:weapp",
    "build:server": "pnpm --filter @geo/server build",
    "build:admin": "pnpm --filter @geo/admin build",
    "build": "pnpm build:shared && pnpm -r --filter \"./apps/*\" build",
    "dev": "pnpm build:shared && pnpm -r --parallel --filter \"./apps/*\" dev",
    "clean": "pnpm -r exec rm -rf dist && rm -rf node_modules",
    "postinstall": "pnpm --filter @geo/shared build"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
