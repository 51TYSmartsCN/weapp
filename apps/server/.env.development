# ============================================================
# 开发环境覆盖配置
# 由 config.ts 在 NODE_ENV !== 'production' 时加载
# ============================================================

# 公司 VPN / Zscaler 等会拦截 HTTPS 替换为自签证书，Node 不读 Keychain，
# 调用 api.weixin.qq.com 会报 UNABLE_TO_GET_ISSUER_CERT_LOCALLY。
# 临时关闭 TLS 校验让后端能联通微信。生产环境务必关闭此项。
NODE_TLS_REJECT_UNAUTHORIZED=0
