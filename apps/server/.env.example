# ============================================================
# 共享基础配置（dev / prod 都会加载）
# 环境专属覆盖项放在 .env.development / .env.production
# 复制本文件为 .env 后填入真实值即可
# ============================================================

# 服务端口
PORT=4000

# MySQL 数据库（Docker 容器，端口 3307）
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASS=your_db_password
DB_NAME=geo_course

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# 微信小程序
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret
