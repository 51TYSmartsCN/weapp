# ============================================================
# 共享基础配置（dev / prod 都会加载）
# 环境专属覆盖项放在 .env.development / .env.production
# 复制本文件为 .env 后填入真实值即可
# ============================================================

# 服务端口
PORT=4000

# 服务监听地址
HOST=0.0.0.0

# 服务对外访问地址(用于拼接图片 URL 等完整链接)
# 开发环境: http://localhost:4000
# 生产环境: https://your-domain.com
BASE_URL=http://localhost:4000

# MySQL 数据库（Docker 容器，端口 3307）
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASS=your_db_password
DB_NAME=geo_course

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# 微信小程序
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret

# 微信小店订单回调(小程序消息推送机制)
# - 在 mp.weixin.qq.com → 开发 → 开发管理 → 消息推送配置 中设置
# - Token:32位随机字符串,可用 python3 -c "import secrets;print(secrets.token_hex(16))" 生成
# - EncodingAESKey:43位base64字符,可用 python3 -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode().rstrip('='))" 生成
# - 回调 URL: https://你的域名/api/wxshop/order/callback
WXSHOP_CALLBACK_TOKEN=your_32_char_token_here
WXSHOP_ENCODING_AES_KEY=your_43_char_aes_key_here
# mock 模式开关:开发环境在 .env.development 设为 1,生产环境在 .env.production 设为 0 或不设置
WXSHOP_MOCK=

# 视频号小店 Webhook(对接.md)
# - 在微信小店后台「服务市场 → 自研 → 消息推送」中配置
# - 回调 URL: https://你的域名/api/channels/webhook
# - 开发环境未配置 Token 时自动开启 mockMode(跳过签名校验)
CHANNELS_TOKEN=your_channels_token_here
CHANNELS_ENCODING_AES_KEY=your_43_char_channels_aes_key_here
# 微信小店主体接口凭证(获取入口: 微信小店商家后台 → 服务市场 → 自研)
# - 与小程序 AppID 不同,AppSecret 只在「重置」时显示一次,必须立即保存
# - 获取 access_token 前需在「自研」页面下方 IP白名单 中添加服务器公网 IP
CHANNELS_APP_ID=your_channels_app_id
CHANNELS_APP_SECRET=your_channels_app_secret

# 后台管理员账号
# - 开发环境:代码内置默认值 admin / admin123,无需配置
# - 生产环境:必须配置,无默认值,请务必修改为强密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password

# 生产环境 CORS 白名单（逗号分隔，仅浏览器访问会带 Origin）
# 示例: https://admin.example.com,https://ops.example.com
CORS_ORIGINS=https://admin.example.com
