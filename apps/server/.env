# ============================================================
# 共享基础配置（dev / prod 都会加载）
# 环境专属覆盖项放在 .env.development / .env.production
# ============================================================

# 服务端口
PORT=4000

# 服务对外访问地址(用于拼接图片 URL 等)
# 开发环境: http://localhost:4000
# 生产环境: https://ty-server-api.tysmarts.cn
BASE_URL=https://ty-server-api.tysmarts.cn

# MySQL 数据库
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASS=geo_root_2024
DB_NAME=geo_course

# JWT
JWT_SECRET=geo_course_dev_secret_change_me
JWT_EXPIRES_IN=7d

# 微信小程序
WECHAT_APPID=wx0714413431ed0de1
WECHAT_SECRET=0139a97e2264d50eab2b7cfa1fb3a295

# 微信小店订单回调(小程序消息推送机制)
# - 在 mp.weixin.qq.com → 开发 → 开发管理 → 消息推送配置 中设置
# - Token 和 EncodingAESKey 必须与小程序后台填写的完全一致
# - 回调 URL: https://你的域名/api/wxshop/order/callback
WXSHOP_CALLBACK_TOKEN=e7ff0d80e7c475dab7d95f9fe254d63c
WXSHOP_ENCODING_AES_KEY=DaeJpOu3iiGD6hznNIbupl1gC7vkZNaGjPi5znwDmds

# 视频号小店 Webhook(对接.md)
# - 在微信小店后台「服务市场 → 自研 → 消息推送」中配置
# - 回调 URL: https://你的域名/api/channels/webhook
# - Token 与 EncodingAESKey 必须与微信小店后台填写的完全一致
# - 开发环境未配置 Token 时自动开启 mockMode(跳过签名校验)
CHANNELS_TOKEN=e7ff0d80e7c475dab7d95f9fe254d63c
CHANNELS_ENCODING_AES_KEY=DaeJpOu3iiGD6hznNIbupl1gC7vkZNaGjPi5znwDmds
# 微信小店主体接口凭证(获取入口: 微信小店商家后台 → 服务市场 → 自研)
# - 与小程序 AppID 不同,AppSecret 只在「重置」时显示一次,必须立即保存
# - 获取 access_token 前需在「自研」页面下方 IP白名单 中添加服务器公网 IP
CHANNELS_APP_ID=wx65240b783b397df0
CHANNELS_APP_SECRET=894c0b6dbcacee2b71945483bbd46ab6
