# ============================================================
# Admin 后台开发环境配置
# ============================================================

# 后端 API 地址（开发环境用相对路径，走 Vite proxy 代理，避免跨域）
VITE_API_BASE_URL=/api

# Vite 代理目标地址（开发环境 proxy 转发到的后端服务）
# VITE_PROXY_TARGET=https://ty-server-api.tysmarts.cn

VITE_PROXY_TARGET=http://localhost:4000